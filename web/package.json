{
  "name": "app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "wasm-pack build --target web rs_lib && vp build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "dev": "wasm-pack build --dev --target web rs_lib && vp dev",
    "preview": "vp preview",
    "preview:cf": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.3",
    "@vite-pwa/sveltekit": "^1.1.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.24",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "latest",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@patternfly/elements": "^5.0.0",
    "img2tempdecal-web": "link:rs_lib/pkg"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": " >=11.0.0",
      "onFail": "download"
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@11.5.3"
}
